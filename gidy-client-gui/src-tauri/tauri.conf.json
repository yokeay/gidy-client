{
  "$schema": "https://raw.githubusercontent.com/nickknapton88/tauri-docs/v2/tooling/cli/schema.json",
  "productName": "gidy-client",
  "version": "0.3.0",
  "identifier": "com.gidy.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "gidy client",
        "width": 980,
        "height": 640,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
